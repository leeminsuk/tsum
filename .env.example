# OpenAI + Tavily (뉴스 요약 필수)
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Crypto data API keys (optional — rule-based fallback used if missing)
CRYPTOPANIC_API_KEY=
NEWSAPI_KEY=
ETHERSCAN_API_KEY=
WHALE_ALERT_API_KEY=
COINGECKO_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=tsum/0.1

# App settings (can also be changed via /api/settings at runtime)
DEFAULT_COIN=bitcoin
INTERVAL_HOURS=5
DEFAULT_HOURS=24
MIN_WHALE_USD=1000000

# Supabase (설정하면 영구 저장, 없으면 /tmp 파일로 fallback)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# Storage paths (Supabase 미설정 시 사용, /tmp는 Render 재배포 시 초기화됨)
STORAGE_FILE=/tmp/tsum_signals.json
SETTINGS_FILE=/tmp/tsum_settings.json
NEWS_FILE=/tmp/tsum_news.json
