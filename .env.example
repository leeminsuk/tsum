# Crypto data API keys (optional — rule-based fallback used if missing)
CRYPTOPANIC_API_KEY=
NEWSAPI_KEY=
ETHERSCAN_API_KEY=
WHALE_ALERT_API_KEY=
COINGECKO_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=tsum/0.1

# App settings (can also be changed via /api/settings at runtime)
DEFAULT_COIN=bitcoin
INTERVAL_HOURS=5
DEFAULT_HOURS=24
MIN_WHALE_USD=1000000

# Storage paths (defaults to /tmp on Render — ephemeral, resets on redeploy)
STORAGE_FILE=/tmp/tsum_signals.json
SETTINGS_FILE=/tmp/tsum_settings.json
